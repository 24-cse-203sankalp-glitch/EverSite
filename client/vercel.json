{
  "version": 2,
  "name": "eversite-client",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/service-worker.js",
      "dest": "/service-worker.js",
      "headers": { "Service-Worker-Allowed": "/" }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "VITE_SIGNALING_SERVER": "https://eversite.onrender.com",
    "VITE_VIDEO_SERVER_URL": "https://eversite.onrender.com",
    "VITE_PINATA_JWT": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..7V_eoI4XvvexWJvXNXSzxcnCKhlQ8f39pG3r9I5iqJA"
  }
}
