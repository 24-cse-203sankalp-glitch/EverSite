{
  "version": 2,
  "name": "eversite-client",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/service-worker.js",
      "dest": "/service-worker.js",
      "headers": { "Service-Worker-Allowed": "/" }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "env": {
    "VITE_SIGNALING_SERVER": "https://eversite-server.onrender.com"
  }
}
